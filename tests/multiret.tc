/* multiret.tc : test fixed multiple return values */

define divmod(int a, int b) -> 2
{
    return a / b, a % b;
}

define swap(int x, int y) -> 2
{
    return y, x;
}

define triple(int n) -> 3
{
    return n, n * 2, n * 3;
}

define main() -> int
{
    int q;
    int r;
    int a;
    int b;
    int c;

    (q, r) = divmod(17, 5);
    if (q != 3) return 1;
    if (r != 2) return 1;

    (q, r) = divmod(100, 13);
    if (q != 7) return 1;
    if (r != 9) return 1;

    (a, b) = swap(10, 20);
    if (a != 20) return 1;
    if (b != 10) return 1;

    (q, _) = divmod(7, 2);
    if (q != 3) return 1;

    (_, r) = divmod(7, 2);
    if (r != 1) return 1;

    (a, b, c) = triple(5);
    if (a != 5) return 1;
    if (b != 10) return 1;
    if (c != 15) return 1;

    return 0;
}
