define fill(byte p[], int n, int val)
{
    int i;
    i = 0;
    while (i < n) {
        p[i] = val;
        i = i + 1;
    }
}

define check(byte p[], int n, int val) -> int
{
    int i;
    i = 0;
    while (i < n) {
        if (p[i] != val) return 1;
        i = i + 1;
    }
    return 0;
}

define main() -> int
{
    int a;
    int b;

    a = alloca(16);
    b = alloca(32);

    fill(a, 16, 'A');
    fill(b, 32, 'B');

    if (check(a, 16, 'A')) return 1;
    if (check(b, 32, 'B')) return 2;

    return 0;
}
