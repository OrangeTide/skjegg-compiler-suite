define memcpy(byte dst[], byte src[], int n) -> int
{
    int i;
    i = 0;
    while (i < n) {
        dst[i] = src[i];
        i = i + 1;
    }
    return n;
}

define strcpy(byte dst[], byte src[]) -> int
{
    int i;
    int c;
    i = 0;
    while (1) {
        c = src[i];
        dst[i] = c;
        if (c == 0) break;
        i = i + 1;
    }
    return i;
}

byte buf[32];

define main() -> int
{
    int n;

    n = strcpy(buf, "abcdef");
    if (n != 6)         return 1;
    if (buf[0] != 'a')  return 1;
    if (buf[5] != 'f')  return 1;
    if (buf[6] != 0)    return 1;

    n = 0;
    while (n < 32) { buf[n] = 0; n = n + 1; }

    memcpy(buf, "XYZ", 3);
    if (buf[0] != 'X')  return 1;
    if (buf[1] != 'Y')  return 1;
    if (buf[2] != 'Z')  return 1;
    if (buf[3] != 0)    return 1;
    return 0;
}
